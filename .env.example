# NextAuth / Auth.js
# These are REQUIRED for authentication to work (both locally and on Vercel)
# For Vercel production: set NEXTAUTH_SECRET (generate with `openssl rand -base64 32`)
# and NEXTAUTH_URL to your production URL e.g. https://your-project.vercel.app
NEXTAUTH_SECRET=your-super-secret-string-at-least-32-characters-long
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
# Only set these if you want Google login. The login page will hide the button if they're missing.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Username / Password users (JSON array).
# Generate passwordHash using: node -e 'console.log(require("bcryptjs").hashSync("yourpassword", 10))'
# Example:
# AUTH_USERS='[{"email":"admin@yourcompany.gr","passwordHash":"$2a$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx","name":"Admin"}]'
AUTH_USERS=

# Optional demo fallback (only used if AUTH_USERS is not set - remove in production)
# You can sign in with demo@example.com / demo1234 when AUTH_USERS is empty.

# Vercel Deployment Notes:
# - Never commit real values in .env* files (they are gitignored).
# - Set the above variables in your Vercel Project → Settings → Environment Variables.
# - In the Vercel UI you will see the variable *names* but the *values* will be hidden/empty when editing (this is normal and secure — values are encrypted and never shown after creation).
# - For production, also update your Google OAuth client with the production redirect URI.
# - NEXTAUTH_URL can often be omitted on Vercel (it auto-detects), but it's safe to set it to your production domain.
